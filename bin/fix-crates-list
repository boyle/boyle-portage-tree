#!/bin/bash
# Usage: ./fix-crates-list path/to/ebuild
# Fixes CRATES list in-place by replacing = with @

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <path/to/ebuild>"
  exit 1
fi

ebuild="$1"

if [[ ! -f "$ebuild" ]]; then
  echo "Error: Ebuild not found at $ebuild"
  exit 1
fi

# Backup original
cp "$ebuild" "${ebuild}.bak"

# Fix CRATES list - replace = with @ but only within the CRATES block
sed -i '
  /^CRATES=/,/^"/ {
    s/\([^[:space:]]*\)=\([^[:space:]]*\)/\1@\2/g
  }
' "$ebuild"

echo "Fixed CRATES list in $ebuild (backup saved as ${ebuild}.bak)"