#!/bin/bash
# create-ebuild - Generate a cargo-based ebuild template
#
# USAGE:
#   create-ebuild <category>/<package> <version> [path/to/Cargo.lock] [options]
#
# EXAMPLES:
#   create-ebuild app-backup/redu 0.2.15
#   create-ebuild app-backup/redu 0.2.15 path/to/Cargo.lock
#   create-ebuild app-backup/redu 0.2.15 --description "ncdu for your restic repo" \\
#                               --homepage "https://github.com/drdo/redu" \\
#                               --repo "drdo" \\
#                               --deps "app-backup/restic"
#
# OUTPUT:
#   Prints a complete ebuild to stdout that can be redirected to a file:
#     create-ebuild app-backup/redu 0.2.15 > app-backup/redu/redu-0.2.15.ebuild
#
# NOTES:
#   1. If metadata.xml doesn't exist in the package directory, create it:
#      mkdir -p <category>/<package>
#      cat > <category>/<package>/metadata.xml << 'EOF'
#      <?xml version="1.0" encoding="UTF-8"?>
#      <!DOCTYPE pkgmetadata SYSTEM "https://www.gentoo.org/dtd/metadata.dtd">
#      <pkgmetadata>
#          <maintainer type="person">
#              <email>your-email@gentoo.org</email>
#              <name>Your Name</name>
#          </maintainer>
#          <upstream>
#              <remote-id type="github">user/repo</remote-id>
#          </upstream>
#      </pkgmetadata>
#      EOF
#   2. To acquire Cargo.lock for the CRATES section:
#      a. First create a basic ebuild without CRATES
#      b. Run: ebuild <category>/<package>-<version>.ebuild unpack
#      c. The Cargo.lock will be available at:
#         /var/tmp/portage/<category>/<package>-<version>/work/<package>-<version>/Cargo.lock
#      d. Then re-run this script with the path to that Cargo.lock
#
#   3. The generated ebuild uses ${PN} and ${PV} correctly for easy version bumping
#   4. Per Gentoo policy, the package itself should NOT be included in CRATES
#
# DEFAULT VALUES:
#   Description: "TODO: Add description"
#   Homepage: "TODO: Add homepage"
#   GitHub user: Attempts to guess from metadata.xml, defaults to package name
#   Dependencies: Empty
#   License: MIT

# Default values
description="TODO: Add description"
homepage="TODO: Add homepage"
github_user=""  # Will try to guess from metadata or default to package name
deps=""
license="MIT"

# Check minimum required arguments
if [[ $# -lt 2 ]]; then
  echo "Usage: $0 <category>/<package> <version> [path/to/Cargo.lock] [options]"
  echo "Example: $0 app-backup/redu 0.2.15"
  echo "Example with options: $0 app-backup/redu 0.2.15 --description \"ncdu for your restic repo\" --homepage \"https://github.com/drdo/redu\" --repo \"drdo\" --deps \"app-backup/restic\""
  exit 1
fi

pkg_full="$1"
version="$2"

# Cargo.lock is optional third argument
if [[ $# -ge 3 && -n "$3" && "$3" != --* ]]; then
  cargo_lock="$3"
  shift 3
else
  cargo_lock=""
  shift 2
fi

# Parse remaining options
while [[ $# -gt 0 ]]; do
  case "$1" in
    --description)
      if [[ -n "$2" ]]; then
        description="$2"
        shift 2
      else
        echo "Error: --description requires a value"
        exit 1
      fi
      ;;
    --homepage)
      if [[ -n "$2" ]]; then
        homepage="$2"
        shift 2
      else
        echo "Error: --homepage requires a value"
        exit 1
      fi
      ;;
    --repo)
      if [[ -n "$2" ]]; then
        github_user="$2"
        shift 2
      else
        echo "Error: --repo requires a value"
        exit 1
      fi
      ;;
    --deps)
      if [[ -n "$2" ]]; then
        deps="$2"
        shift 2
      else
        echo "Error: --deps requires a value"
        exit 1
      fi
      ;;
    --license)
      if [[ -n "$2" ]]; then
        license="$2"
        shift 2
      else
        echo "Error: --license requires a value"
        exit 1
      fi
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

# Extract category and package name
IFS='/' read -r category package <<< "$pkg_full"

# Try to guess GitHub user if not provided
if [[ -z "$github_user" ]]; then
  # Check if there's metadata.xml to get upstream info
  metadata_file="./${category}/${package}/metadata.xml"
  if [[ -f "$metadata_file" ]]; then
    # Extract user/repo from metadata, then take just the user part
    github_repo=$(grep -oP '(?<=<remote-id type="github">)[^<]+' "$metadata_file" | head -1)
    if [[ -n "$github_repo" ]]; then
      github_user=$(echo "$github_repo" | cut -d'/' -f1)
    fi
  fi
  
  # If still not found, use a heuristic: default to package name
  if [[ -z "$github_user" ]]; then
    github_user="$package"
  fi
fi

# Generate CRATES list if Cargo.lock is provided
crates_section=""
if [[ -n "$cargo_lock" && -f "$cargo_lock" ]]; then
  # Extract name@version pairs from Cargo.lock
  crates_list=$(grep -A 2 '\[\[package\]\]' "$cargo_lock" | \
    grep -E '(name|version)' | \
    sed -n 'N;s/\n/ /p' | \
    sed -e 's/.*name = "\([^"]*\)".*version = "\([^"]*\)".*/\1@\2/' | \
    sort)
    
  if [[ -n "$crates_list" ]]; then
    crates_section="CRATES=\""
    while IFS= read -r line; do
      crates_section+="	$line
"
    done <<< "$crates_list"
    crates_section+="\""
  fi
fi

# Generate the ebuild template
cat << EOF
# Copyright 2026 Gentoo Authors
# Distributed under the terms of the GNU General Public License v2

EAPI=8

${crates_section}

inherit cargo

DESCRIPTION="${description}"
HOMEPAGE="${homepage}"
SRC_URI="
	https://github.com/${github_user}/${package}/archive/refs/tags/v\${PV}.tar.gz -> \${P}.tar.gz
	\${CARGO_CRATE_URIS}
"

LICENSE="${license}"
SLOT="0"
KEYWORDS="~amd64"

RDEPEND="${deps}"
QA_FLAGS_IGNORED="/usr/bin/\${PN}"

src_install() {
	cargo_src_install
}
EOF