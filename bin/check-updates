#!/bin/bash

set -euo pipefail

PARALLEL=0
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/check-updates"
CACHE_TTL=3600

show_help() {
    cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Check for upstream updates of packages in the overlay.

OPTIONS
    -h, --help          Show this help message
    -p, --parallel N    Run N concurrent API requests (default: 1)
    --no-cache          Disable caching of API responses
    --clear-cache       Clear cache and exit

ENVIRONMENT
    PORTDIR_OVERLAY     Path to overlay (default: git root)
    GITHUB_TOKEN        GitHub API token for higher rate limits

CACHE
    API responses are cached for 1 hour in ~/.cache/check-updates
EOF
}

for cmd in xmllint grep sort tail ls curl sed jq; do
    if ! command -v $cmd &>/dev/null; then
        echo "error: $cmd missing" >&2
        exit 1
    fi
done

version_compare() {
    local v1="$1"
    local v2="$2"
    if [[ "$v1" == "$v2" ]]; then
        echo "0"
    elif printf '%s\n%s\n' "$v1" "$v2" | sort -V | head -1 | grep -q "^${v1}$"; then
        echo "-1"
    else
        echo "1"
    fi
}

version_gt() {
    [[ "$(version_compare "$1" "$2")" == "1" ]]
}

version_lt() {
    [[ "$(version_compare "$1" "$2")" == "-1" ]]
}

if [[ -z "${PORTDIR_OVERLAY:-}" ]]; then
    if git rev-parse --show-toplevel &>/dev/null; then
        PORTDIR_OVERLAY="$(git rev-parse --show-toplevel)"
    else
        echo "ERROR: PORTDIR_OVERLAY not set and not in a git repository" >&2
        exit 1
    fi
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -p|--parallel)
            PARALLEL="${2:-4}"
            shift 2
            ;;
        --no-cache)
            CACHE_TTL=0
            shift
            ;;
        --clear-cache)
            rm -rf "$CACHE_DIR"
            echo "Cache cleared"
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

mkdir -p "$CACHE_DIR"

get_cached() {
    local key="$1"
    local cache_file="${CACHE_DIR}/${key}"
    if [[ $CACHE_TTL -gt 0 && -f "$cache_file" ]]; then
        local age=$(($(date +%s) - $(stat -c %Y "$cache_file" 2>/dev/null || stat -f %m "$cache_file")))
        if [[ $age -lt $CACHE_TTL ]]; then
            cat "$cache_file"
            return 0
        fi
    fi
    return 1
}

set_cached() {
    local key="$1"
    local value="$2"
    echo "$value" > "${CACHE_DIR}/${key}"
}

get_EGIT_REPO_URI() {
    local CATEGORY="$1"
    local PN="$2"
    local metadata_file="${PORTDIR_OVERLAY}/${CATEGORY}/${PN}/metadata.xml"
    if [[ ! -f "$metadata_file" ]]; then
        echo ""
        return
    fi
    xmllint --xpath "string(//upstream/remote-id[@type='github'])" "$metadata_file" 2>/dev/null || echo ""
}

get_upstream_version() {
    local EGIT_REPO_URI="$1"
    if [[ -z "$EGIT_REPO_URI" ]]; then
        echo ""
        return
    fi

    local cache_key="gh_${EGIT_REPO_URI//\//_}"
    if cached=$(get_cached "$cache_key"); then
        echo "$cached"
        return
    fi

    local headers=(-H "Accept: application/vnd.github+json")
    headers+=(-H "X-GitHub-Api-Version: 2022-11-28")
    if [[ -n "${GITHUB_TOKEN:-}" ]]; then
        headers+=(-H "Authorization: Bearer $GITHUB_TOKEN")
    fi

    local version=""
    local rate_limited=false

    if version=$(curl -s "${headers[@]}" "https://api.github.com/repos/${EGIT_REPO_URI}/releases/latest" | jq -r '.tag_name // empty | ltrimstr("v")') && [[ -n "$version" ]]; then
        set_cached "$cache_key" "$version"
        echo "$version"
        return
    fi

    local http_code=$(curl -s -o /dev/null -w "%{http_code}" "${headers[@]}" "https://api.github.com/repos/${EGIT_REPO_URI}/releases/latest")
    if [[ "$http_code" == "403" ]]; then
        local remaining=$(curl -s "${headers[@]}" -o /dev/null -w "%{http_code}" -I "https://api.github.com/repos/${EGIT_REPO_URI}" 2>/dev/null | grep -i ratelimit-remaining | awk '{print $2}' || echo "0")
        if [[ "${remaining:-0}" == "0" ]]; then
            rate_limited=true
        fi
    fi

    if [[ "$rate_limited" == "true" ]]; then
        if [[ -n "${GITHUB_TOKEN:-}" ]]; then
            echo "rate-limited" >&2
        else
            echo "rate-limited (set GITHUB_TOKEN for higher limits)" >&2
        fi
        echo ""
        return
    fi

    if version=$(curl -s -L "${headers[@]}" "https://api.github.com/repos/${EGIT_REPO_URI}/tags" | jq -r '.[0].name // empty | ltrimstr("v")') && [[ -n "$version" ]]; then
        set_cached "$cache_key" "$version"
        echo "$version"
        return
    fi

    echo ""
}

get_installed_version() {
    local PN="$1"
    local installed
    installed=$(ls -d /var/db/pkg/*/"${PN}"-*/ 2>/dev/null | grep -v '/acct-' | head -1)
    if [[ -z "$installed" ]]; then
        echo ""
        return
    fi
    basename "$installed" | sed 's/^'"${PN}"'-//; s/-r[0-9]*$//'
}

get_highest_ebuild_version() {
    local category="$1"
    local PN="$2"
    local pkg_dir="${PORTDIR_OVERLAY}/${category}/${PN}"
    local ebuilds
    ebuilds=$(ls "${pkg_dir}"/${PN}-*.ebuild 2>/dev/null | grep -v '9999' || true)
    if [[ -z "$ebuilds" ]]; then
        echo ""
        return
    fi
    echo "$ebuilds" | sort -V | tail -1 | sed 's/.*-\([0-9].*\)\.ebuild/\1/; s/-r[0-9]*$//'
}

check_pkg() {
    local PN="$1"
    local CATEGORY="$2"

    local EGIT_REPO_URI PV_EBUILD PV_INSTALLED PV_UPSTREAM
    local icon="  " suffix="" parts=()
    local padding=""
    local pad_len=$((MAX_PN_LEN - ${#PN} + 2))
    printf -v padding '%*s' "$pad_len"

    EGIT_REPO_URI=$(get_EGIT_REPO_URI "$CATEGORY" "$PN")
    if [[ -z "$EGIT_REPO_URI" ]]; then
        echo "? ${PN}:"
        return
    fi

    PV_UPSTREAM=$(get_upstream_version "$EGIT_REPO_URI")
    if [[ -z "$PV_UPSTREAM" ]]; then
        echo "! ${PN}:"
        return
    fi

    PV_EBUILD_RAW=$(get_highest_ebuild_version "$CATEGORY" "$PN")
    PV_INSTALLED_RAW=$(get_installed_version "$PN")

    # Store raw for display, strip -r suffix for comparison
    local PV_EBUILD="${PV_EBUILD_RAW}"
    local PV_INSTALLED="${PV_INSTALLED_RAW}"
    local PV_EBUILD_CMP="${PV_EBUILD_RAW%-r*}"
    local PV_INSTALLED_CMP="${PV_INSTALLED_RAW%-r*}"
    local PV_UPSTREAM_CMP="${PV_UPSTREAM%-r*}"

    # Use stripped versions for comparisons

    if [[ -n "$PV_INSTALLED" && -n "$PV_EBUILD" ]]; then
        if version_gt "$PV_INSTALLED_CMP" "$PV_EBUILD_CMP"; then
            icon="~ "
            parts+=("WARNING: ebuild ${PV_EBUILD} is behind installed")
        elif version_gt "$PV_UPSTREAM_CMP" "$PV_EBUILD_CMP"; then
            icon="+ "
            if [[ "$PV_INSTALLED_CMP" == "$PV_EBUILD_CMP" ]]; then
                parts+=("installed ${PV_INSTALLED}")
            else
                parts+=("installed ${PV_INSTALLED}")
                parts+=("ebuild ${PV_EBUILD}")
            fi
        elif version_lt "$PV_INSTALLED_CMP" "$PV_EBUILD_CMP"; then
            icon="↑ "
            parts+=("installed ${PV_INSTALLED}")
        fi
    elif [[ -n "$PV_INSTALLED" ]]; then
        if version_gt "$PV_UPSTREAM_CMP" "$PV_INSTALLED_CMP"; then
            icon="↑ "
            parts+=("installed ${PV_INSTALLED}")
        elif version_gt "$PV_INSTALLED_CMP" "$PV_UPSTREAM_CMP"; then
            icon="~ "
            parts+=("WARNING: ebuild ${PV_EBUILD_RAW:-none} is behind installed")
        fi
    elif [[ -n "$PV_EBUILD" ]]; then
        if version_gt "$PV_UPSTREAM_CMP" "$PV_EBUILD_CMP"; then
            icon="+ "
            parts+=("ebuild ${PV_EBUILD}")
        else
            icon="o "
        fi
    fi

    if [[ ${#parts[@]} -gt 0 ]]; then
        local joined=""
        local sep=""
        for part in "${parts[@]}"; do
            joined="${joined}${sep}${part}"
            sep=", "
        done
        suffix="(${joined})"
    fi

    echo -n "${icon}${PN}:${padding} ${PV_UPSTREAM}"
    if [[ -n "$suffix" ]]; then
        echo " ${suffix}"
    else
        echo ""
    fi
}

discover_packages() {
    local overlay="$1"
    while IFS= read -r pkg_dir; do
        rel_path="${pkg_dir#$overlay/}"
        CATEGORY="${rel_path%%/*}"
        PN="${rel_path#*/}"
        if [[ "$CATEGORY" == "acct-user" || "$CATEGORY" == "acct-group" ]]; then
            continue
        fi
        echo "$PN $CATEGORY"
    done < <(find "$overlay" -name "*.ebuild" -type f -exec dirname {} \; | sort -u)
}

get_max_len() {
    local max_len=0
    while read -r PN CATEGORY; do
        local len=${#PN}
        if [[ $len -gt $max_len ]]; then
            max_len=$len
        fi
    done < <(discover_packages "$PORTDIR_OVERLAY")
    echo $max_len
}

export -f get_EGIT_REPO_URI
export -f get_upstream_version
export -f get_installed_version
export -f get_highest_ebuild_version
export -f check_pkg
export -f get_cached
export -f set_cached
export -f version_compare
export -f version_gt
export -f version_lt
export CACHE_DIR
export CACHE_TTL
export PORTDIR_OVERLAY
export GITHUB_TOKEN

MAX_PN_LEN=$(get_max_len)
export MAX_PN_LEN

if [[ $PARALLEL -gt 0 ]]; then
    while read -r PN CATEGORY; do
        check_pkg "$PN" "$CATEGORY" 2>&1
    done < <(discover_packages "$PORTDIR_OVERLAY") | sort -k2,2
else
    while read -r PN CATEGORY; do
        check_pkg "$PN" "$CATEGORY" 2>&1
    done < <(discover_packages "$PORTDIR_OVERLAY") | sort -k2,2
fi
